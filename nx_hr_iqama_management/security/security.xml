        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>

    <record id="rule_hr_iqama_fee_line_multi_company" model="ir.rule">
        <field name="name">Iqama fee lines multi company</field>
        <field name="model_id" ref="model_hr_iqama_fee_line"/>
        <field name="domain_force">[('iqama_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hr.group_hr_user')), (4, ref('base.group_system'))]"/>
    </record>

    <record id="rule_hr_iqama_timeline_multi_company" model="ir.rule">
        <field name="name">Iqama timeline multi company</field>
        <field name="model_id" ref="model_hr_iqama_timeline"/>
        <field name="domain_force">[('iqama_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('base.group_system'))]"/>
    </record>
</odoo>
