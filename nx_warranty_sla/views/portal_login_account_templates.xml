                                                    <span class="nx-enterprise-login__partner-logo" aria-hidden="true"><img t-attf-src="/nx_warranty_sla/static/src/img/partners/#{partner}.#{'png' if partner == 'ibm' else 'jpg'}" alt=""/></span>
