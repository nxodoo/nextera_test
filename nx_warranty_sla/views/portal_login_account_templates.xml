                        <div class="nx-footer-shell" t-attf-dir="#{'rtl' if nx_footer_is_arabic else 'ltr'}">
                            <div class="row g-4">
                                <div class="col-lg-5">
                                    <div class="nx-footer-column nx-footer-brand-column">
                                        <div class="nx-footer-kicker"><t t-esc="'حلول رقمية متكاملة' if nx_footer_is_arabic else 'Integrated Digital Solutions'"/></div>
                                        <h3 class="nx-footer-brand-title">NextEra</h3>
                                        <p class="nx-footer-lead">
                                            <t t-esc="'العلاقة بين تطور الأعمال والتقدم التكنولوجي تزداد ترابطًا ونموًا بشكل مستمر.' if nx_footer_is_arabic else 'The relationship between business evolution and technological advancement is constantly growing.'"/>
                                        </p>
                                        <p class="nx-footer-story mb-0">
                                            <strong><t t-esc="'عن NextEra:' if nx_footer_is_arabic else 'About NextEra:'"/></strong>
