                                        </p>
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="nx-footer-column">
                                        <h5 class="nx-footer-heading"><t t-esc="'روابط مهمة' if nx_footer_is_arabic else 'Useful Links'"/></h5>
                                        <div class="nx-footer-links-grid">
                                            <a href="/my/tickets"><t t-esc="'التذاكر' if nx_footer_is_arabic else 'Tickets'"/></a>
                                            <a t-if="request and request.env and request.env.user and (request.env.user.has_group('base.group_user') or (request.env.user._fields.get('portal_ticket_role') and request.env.user.portal_ticket_role == 'admin'))" href="/my/orders"><t t-esc="'الطلبات' if nx_footer_is_arabic else 'Orders'"/></a>
                                            <a href="/my/elearning"><t t-esc="'التعلم الإلكتروني' if nx_footer_is_arabic else 'E-Learning'"/></a>
                                            <a href="/my/knowledge"><t t-esc="'المعرفة' if nx_footer_is_arabic else 'Knowledge'"/></a>
                                            <a href="/my/warranties"><t t-esc="'الضمانات' if nx_footer_is_arabic else 'Warranties'"/></a>
                                            <a href="/contactus"><t t-esc="'تواصل معنا' if nx_footer_is_arabic else 'Contact us'"/></a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3">
                                    <div class="nx-footer-column nx-footer-connect-column" id="connect">
                                        <h5 class="nx-footer-heading"><t t-esc="'تواصل معنا' if nx_footer_is_arabic else 'Connect'"/></h5>
