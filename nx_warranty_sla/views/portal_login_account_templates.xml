                                                <h4>ERP &amp; Business Apps</h4>
                                                <div class="nx-enterprise-login__partner-logos">
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/sap.jpg" alt="SAP"/></span>
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/odoo.jpg" alt="Odoo"/></span>
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/micro.jpg" alt="MS Dynamics"/></span>
                                                </div>
                                            </div>
                                            <div class="nx-enterprise-login__partner-card">
                                                <h4>Low Code</h4>
                                                <div class="nx-enterprise-login__partner-logos">
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/micro_powerapps.jpg" alt="PowerApps"/></span>
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/creatio.jpg" alt="Creatio"/></span>
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/elsa.jpg" alt="Elsa"/></span>
                                                </div>
                                            </div>
                                            <div class="nx-enterprise-login__partner-card">
                                                <h4>IT Management</h4>
                                                <div class="nx-enterprise-login__partner-logos">
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/nexthink.jpg" alt="Nexthink"/></span>
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/ivanti.jpg" alt="Ivanti"/></span>
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/dell.jpg" alt="Dell"/></span>
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/lenovo.jpg" alt="Lenovo"/></span>
                                                </div>
                                            </div>
                                            <div class="nx-enterprise-login__partner-card">
                                                <h4>Automation</h4>
                                                <div class="nx-enterprise-login__partner-logos">
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/Uipath.jpg" alt="UiPath"/></span>
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/automation.jpg" alt="Automation Anywhere"/></span>
                                                </div>
                                            </div>
                                            <div class="nx-enterprise-login__partner-card">
                                                <h4>Workflow &amp; BPM</h4>
                                                <div class="nx-enterprise-login__partner-logos">
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/elsa.jpg" alt="Elsa"/></span>
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/ibm.png" alt="IBM"/></span>
                                                </div>
                                            </div>
                                            <div class="nx-enterprise-login__partner-card">
                                                <h4>Customizes &amp; AI</h4>
                                                <div class="nx-enterprise-login__partner-logos">
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/flutter.jpg" alt="Flutter"/></span>
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/dotnet.jpg" alt=".NET"/></span>
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/wordpress.jpg" alt="WordPress"/></span>
                                                    <span class="nx-enterprise-login__partner-logo"><img src="/nx_warranty_sla/static/src/img/partners/bi.jpg" alt="Power BI"/></span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </aside>

                            <div class="nx-enterprise-login__panel">
                                <div class="nx-enterprise-login__panel-card">
                                    <div class="nx-enterprise-login__panel-brand">
                                        <img src="/nx_warranty_sla/static/src/img/img.png" alt="NextEra" class="nx-enterprise-login__panel-logo nx-enterprise-login__panel-logo--nextera"/>
                                    </div>
                                    <div class="oe_website_login_container" t-out="0"/>
                                </div>
                            </div>
                        </div>
                    </section>
                </t>
            </xpath>
        </template>

        <template id="web_login_nextera_form" inherit_id="web.login" priority="95">
            <xpath expr="//form[contains(@t-attf-class, 'oe_login_form')]" position="replace">
                <form t-attf-class="oe_login_form nx-enterprise-login__form #{'' if login else 'd-none'}"
                      role="form"
                      t-attf-action="/web/login"
                      method="post"
                      onsubmit="this.action = '/web/login' + location.hash">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <div class="nx-enterprise-login__welcome">Welcome Back</div>
                    <h1 class="nx-enterprise-login__title">Sign in to your workspace</h1>
                    <p class="nx-enterprise-login__subtitle">
                        Access your dashboard and continue driving growth.
                    </p>

                    <owl-component t-if="not login" name="web.user_switch"/>

                    <div class="mb-3" t-if="databases and len(databases) &gt; 1">
                        <label for="db" class="form-label">Database</label>
                        <div class="input-group">
                            <input type="text"
                                   name="db"
                                   t-att-value="request.db"
                                   id="db"
                                   class="form-control"
                                   required="required"
                                   readonly="readonly"/>
                            <a role="button" href="/web/database/selector" class="btn btn-nx-login-secondary">Select</a>
                        </div>
                    </div>

                    <div class="mb-3 field-login">
                        <label for="login" class="form-label">Email Address</label>
                        <input type="text"
                               name="login"
                               t-att-value="login"
                               id="login"
                               class="form-control"
                               placeholder="name@company.com"
                               required="required"
                               autocapitalize="off"
                               autocomplete="username"/>
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label">Password</label>
                        <input type="password"
                               name="password"
                               id="password"
                               class="form-control"
                               placeholder="Enter your password"
                               required="required"
                               autocomplete="current-password"
                               t-att-autofocus="'autofocus' if login else None"
                               maxlength="4096"/>
                    </div>

                    <p class="alert alert-danger" t-if="error" role="alert">
                        <t t-esc="error"/>
                    </p>
                    <p class="alert alert-success" t-if="message" role="status">
                        <t t-esc="message"/>
                    </p>

                    <div class="nx-enterprise-login__utility-row">
                        <label class="nx-enterprise-login__remember">
                            <input type="checkbox" class="form-check-input"/>
                            <span>Remember me</span>
                        </label>
                        <a t-if="reset_password_enabled"
                           tabindex="1"
                           class="nx-enterprise-login__link"
                           t-attf-href="/web/reset_password?{{ keep_query() }}">
                            Forgot your password?
                        </a>
                    </div>

                    <div class="oe_login_buttons nx-enterprise-login__actions">
                        <button type="submit" class="btn btn-nx-login-primary">Sign In</button>
                        <a t-if="signup_enabled"
                           class="btn btn-nx-login-secondary"
                           t-attf-href="/web/signup?{{ keep_query() }}">
                            Register
                        </a>
                        <div class="o_login_auth"/>
                    </div>

                    <div t-if="debug" class="text-center mt-3">
                        <button type="submit" name="redirect" value="/web/become" class="btn btn-link btn-sm">
                            Log in as superuser
                        </button>
                    </div>

                    <div class="nx-enterprise-login__support">
                        For technical support and onboarding programs, reach out at
                        <a href="mailto:info@nexteramea.com">info@nexteramea.com</a>
                    </div>

                    <input type="hidden" name="type" value="password"/>
                    <input type="hidden" name="redirect" t-att-value="redirect or '/my/home'"/>
                </form>
            </xpath>
        </template>

        <template id="portal_side_name_dropdown" inherit_id="portal.side_content" priority="80">
            <xpath expr="//div[hasclass('d-flex') and hasclass('flex-column') and hasclass('justify-content-center')]/h5" position="replace">
                <t t-if="request.website.portal_mode == 'warranty'">
                    <div>
                        <div class="d-flex align-items-center gap-2">
                            <h5 class="mb-0" t-out="user_id.name"/>
                            <div class="dropdown">
                                <a href="#" class="text-decoration-none text-muted" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fa fa-chevron-down small"/>
                                </a>
                                <div class="dropdown-menu">
                                    <a class="dropdown-item" href="/my/home">
                                        <i class="fa fa-id-card-o me-2"/> My Account
                                    </a>
                                    <a class="dropdown-item" href="/web/session/logout?redirect=/">
                                        <i class="fa fa-sign-out me-2"/> Logout
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="text-muted small mt-1 d-flex align-items-start gap-1" t-if="user_id.partner_id.contact_address">
                            <i class="fa fa-map-marker mt-1"/>
                            <span t-out="user_id.partner_id.contact_address"/>
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <h5 class="mb-0" t-out="user_id.name"/>
                    <div class="text-muted small mt-1" t-out="user_id.commercial_partner_id.name"/>
                </t>
            </xpath>
            <xpath expr="//div[hasclass('o_portal_my_details')]" position="replace">
                <t t-if="request.website.portal_mode != 'warranty'">
                    <div class="o_portal_my_details">
                        <div t-field="user_id.partner_id" t-options='{"widget": "contact", "fields": ["email", "phone", "address"]}'/>
                    </div>
                </t>
            </xpath>
            <xpath expr="//a[contains(@href, '/my/account') or contains(@href, '/my/details')]" position="replace">
                <t t-if="request.website.portal_mode == 'warranty'">
                    <a href="/my/account" class="btn btn-link p-0 mt-3">
                        <i class="fa fa-pencil me-1"/> Edit Profile
                    </a>
                </t>
                <t t-else="">
                    <a role="button" href="/my/account" class="btn btn-link p-0 mt-3"><i class="fa fa-pencil"/> Edit information</a>
                </t>
            </xpath>
        </template>

        <template id="portal_my_details_remove_invoice_fields" inherit_id="account.portal_my_details_fields" priority="95">
            <xpath expr="//small[contains(@class, 'form-text') and contains(., 'You can choose how you want us to send your invoices')]" position="replace"/>
            <xpath expr="//select[@name='invoice_sending_method']/ancestor::div[hasclass('row')][1]" position="replace"/>
            <xpath expr="//select[@name='invoice_edi_format']/ancestor::div[hasclass('row')][1]" position="replace"/>
        </template>

        <template id="portal_my_details_nextera_theme" inherit_id="portal.portal_my_details" priority="90">
            <xpath expr="//t[@t-call='portal.portal_layout']" position="inside">
                <t t-if="request.website.portal_mode == 'warranty'" t-set="no_breadcrumbs" t-value="True"/>
            </xpath>
            <xpath expr="//form[@action='/my/account']" position="before">
                <t t-if="request.website.portal_mode == 'warranty'">
                    <style>
                        .nx-account-card {
                            border: 1px solid #dfe9ee;
                            border-radius: 20px;
                            background: #ffffff;
                            box-shadow: 0 10px 28px rgba(11, 30, 44, 0.06);
                            padding: 28px;
                        }
                        .nx-account-card .nx-account-eyebrow {
                            display: inline-flex;
                            align-items: center;
                            gap: 8px;
                            border-radius: 999px;
                            background: #edf7f8;
                            color: #0c6d71;
                            font-size: 0.85rem;
                            font-weight: 700;
                            padding: 7px 14px;
                        }
                        .nx-account-card h1 {
                            color: #103543;
                            font-size: clamp(2rem, 3.2vw, 2.7rem);
                            font-weight: 800;
                            letter-spacing: -0.03em;
                        }
                        .nx-account-card .nx-account-copy {
                            color: #4d6674;
                            font-size: 1rem;
                            line-height: 1.7;
                            max-width: 44rem;
                        }
                        .nx-account-card label,
                        .nx-account-card .col-form-label {
                            color: #103543;
                            font-weight: 700;
                            margin-bottom: 0.35rem;
                        }
                        .nx-account-card .form-control,
                        .nx-account-card .form-select {
                            min-height: 56px;
                            border: 1px solid #d4e3e8;
                            border-radius: 14px;
                            background: #fbfdfd;
                            box-shadow: none;
                            color: #103543;
                            font-size: 1.05rem;
                        }
                        .nx-account-card .form-control:focus,
                        .nx-account-card .form-select:focus {
                            border-color: #17a3a8;
                            box-shadow: 0 0 0 0.25rem rgba(23, 163, 168, 0.12);
                        }
                        .nx-account-card .form-control[readonly],
                        .nx-account-card .form-control:disabled,
                        .nx-account-card .form-select:disabled {
                            background: #f0f4f6;
                            color: #7b8f9c;
                        }
                        .nx-account-card .btn {
                            min-width: 136px;
                            border-radius: 12px;
                            font-weight: 700;
                            padding: 0.8rem 1.2rem;
                        }
                        .nx-account-card .btn-primary {
                            background: linear-gradient(130deg, #0f6c6f 0%, #17a3a8 100%);
                            border-color: transparent;
                        }
                        .nx-account-card .btn-light {
                            border: 1px solid #d4e3e8;
                            background: #ffffff;
                            color: #103543;
                        }
                        .nx-account-card .text-danger,
                        .nx-account-card .invalid-feedback {
                            color: #c14444 !important;
                        }
                        @media (max-width: 991.98px) {
                            .nx-account-card {
                                padding: 22px 18px;
                            }
                        }
                    </style>
                </t>
            </xpath>
            <xpath expr="//div[hasclass('row') and hasclass('o_portal_details')]" position="replace">
                <t t-if="request.website.portal_mode == 'warranty'">
                    <div class="row o_portal_details">
                        <div class="col-12">
                            <div class="nx-account-card">
                                <div class="nx-account-eyebrow mb-3">
                                    <i class="fa fa-user-circle-o"/>
                                    Profile Settings
                                </div>
                                <h1 class="mb-3">Edit Profile</h1>
                                <p class="nx-account-copy mb-4">
                                    Keep your contact details up to date so tickets, orders, and warranty communication reach the right person.
                                </p>
                                <div class="row">
                                    <t t-call="portal.portal_my_details_fields"/>
                                    <input type="hidden" name="redirect" t-att-value="redirect"/>
                                </div>
                                <div class="d-flex flex-wrap justify-content-end gap-2 mt-4">
                                    <a href="/my/home" class="btn btn-light">Cancel</a>
                                    <button type="submit" class="btn btn-primary">Save Changes</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <div class="row o_portal_details">
                        <div class="col-lg-8">
                            <div class="row">
                                <t t-call="portal.portal_my_details_fields"/>
                                <input type="hidden" name="redirect" t-att-value="redirect"/>
                            </div>
                            <div class="clearfix text-end mb-5">
                                <a href="/my/" class="btn btn-light me-2">
                                    Discard
                                </a>
                                <button type="submit" class="btn btn-primary float-end">
                                    Save
                                </button>
                            </div>
                        </div>
                    </div>
                </t>
            </xpath>
        </template>

        <template id="website_footer_nextera_theme" inherit_id="website.footer_custom" priority="90">
