        <template id="website_footer_copyright_nextera" inherit_id="website.footer_copyright_company_name" priority="95">
            <xpath expr="//span[hasclass('o_footer_copyright_name')]" position="replace">
                <t t-if="request and request.website and request.website.portal_mode == 'warranty'">
                    <t t-set="nx_footer_is_arabic" t-value="request and request.env and request.env.lang and request.env.lang.startswith('ar')"/>
                    <a href="/my/home" class="o_footer_copyright_name me-2" style="color: #f4fbfb !important; text-decoration: none;">
                        <t t-esc="'حقوق النشر © NextEra' if nx_footer_is_arabic else 'Copyright © NextEra'"/>
                    </a>
                </t>
                <span t-else="" class="o_footer_copyright_name me-2">Copyright &amp;copy; Company name</span>
            </xpath>
        </template>

        <template id="portal_footer_language_selector_nextera" inherit_id="portal.footer_language_selector" priority="99">
            <xpath expr="//t[@id='language_selector_call']" position="replace">
                <t t-if="request and request.website and request.website.portal_mode == 'warranty'">
                    <t t-if="len(frontend_languages) &gt; 1">
                        <span class="js_language_selector d-print-none ms-2">
                            <t t-set="active_lang" t-value="frontend_languages[lang]"/>
                            <t t-foreach="frontend_languages.values()" t-as="lg">
                                <a t-att-href="url_localized(lang_code=lg.code, prefetch_langs=True, force_default_lang=True)"
                                   t-att-title="lg.name.split('/').pop()"
                                   t-att-data-url_code="lg.url_code"
                                   t-attf-class="js_change_lang #{active_lang == lg and 'active' or ''}"
                                   t-att-style="'color: %s !important; text-decoration: none; font-weight: 500;' % ('#17a3a8' if active_lang == lg else '#f4fbfb')">
                                    <t t-esc="lg.name.split('/').pop()"/>
                                </a>
                                <t t-if="not lg_last">
                                    <span style="color: #f4fbfb !important; padding: 0 0.6rem;">|</span>
                                </t>
                            </t>
                        </span>
                    </t>
                </t>
                <t t-else="" id="language_selector_call" t-call="portal.language_selector">
                    <t t-set="_div_classes" t-value="(_div_classes or '') + ' dropup'"/>
                </t>
            </xpath>
        </template>

        <template id="website_footer_hide_brand_promotion" inherit_id="web.brand_promotion" priority="99">
            <xpath expr="//div[hasclass('o_brand_promotion')]" position="replace">
                <div class="o_brand_promotion d-none"/>
            </xpath>
        </template>
