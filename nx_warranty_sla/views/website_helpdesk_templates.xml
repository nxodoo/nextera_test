        <template id="nx_website_helpdesk_footer_restyle" inherit_id="website_helpdesk.footer" priority="90">
            <xpath expr="//div[hasclass('d-flex') and hasclass('gap-2')]" position="replace"/>
        </template>

        <template id="nx_website_helpdesk_team_safe_form_view" inherit_id="website_helpdesk.team" priority="95">
            <xpath expr="//div[hasclass('mt-4')]" position="replace">
                <div class="mt-4">
                    <t t-set="nx_team_form_view" t-value="team.sudo().website_form_view_id"/>
                    <t t-if="nx_team_form_view and nx_team_form_view.key" t-call="{{ nx_team_form_view.key }}"/>
                    <t t-else="" t-call="website_helpdesk.ticket_submit_form"/>
                </div>
            </xpath>
        </template>
    </data>
