<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="portal_my_home_warranty_entry" inherit_id="portal.portal_my_home" priority="30">
            <xpath expr="//div[contains(@class, 'o_portal_doc_spinner')]" position="attributes">
                <attribute name="class" add="d-none" separator=" "/>
            </xpath>
            <xpath expr="//div[hasclass('o_portal_docs')]" position="inside">
                <t t-if="request.website.portal_mode == 'warranty'">

                    <t t-call="portal.portal_docs_entry">
                        <t t-set="title">Warranties</t>
                        <t t-set="url">/my/warranties</t>
                        <t t-set="count" t-value="warranty_count"/>
                    </t>

                </t>
            </xpath>
            <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
                <t t-if="not (request and request.env and request.env.user and (request.env.user.has_group('base.group_user') or (request.env.user._fields.get('portal_ticket_role') and request.env.user.portal_ticket_role == 'admin')))">
                    <style>
                        .o_portal .o_portal_docs .o_portal_index_card > a[href*="/my/orders"],
                        .o_portal_wrap .o_portal_docs .o_portal_index_card > a[href*="/my/orders"] {
                            display: none !important;
                        }
                    </style>
                </t>
                <style>
                    .o_portal .o_portal_content h3,
                    .o_portal_wrap .o_portal_content h3 {
                        font-weight: 700;
                        letter-spacing: -0.02em;
                    }
                    .o_portal .o_portal_docs .o_portal_index_card > a,
                    .o_portal_wrap .o_portal_docs .o_portal_index_card > a {
                        position: relative;
                        border: 1px solid #dfe9ee;
                        border-radius: 16px;
                        background: #ffffff !important;
                        transition: all 0.2s ease;
                        box-shadow: 0 6px 16px rgba(11, 30, 44, 0.05);
                        padding: 18px 16px !important;
                    }
                    .o_portal .o_portal_docs .o_portal_index_card > a:hover,
                    .o_portal_wrap .o_portal_docs .o_portal_index_card > a:hover {
                        transform: translateY(-2px);
                        border-color: #8ecfd3;
                        box-shadow: 0 12px 24px rgba(11, 80, 84, 0.13);
                    }
                    .o_portal .o_portal_docs .o_portal_index_card > a::before,
                    .o_portal_wrap .o_portal_docs .o_portal_index_card > a::before {
                        content: "";
                        position: absolute;
                        top: 0;
                        left: 0;
                        right: 0;
                        height: 4px;
                        border-top-left-radius: 16px;
                        border-top-right-radius: 16px;
                        background: linear-gradient(90deg, #0a8f94 0%, #1eb0b5 100%);
                        opacity: 0.9;
                    }
                    .o_portal .o_portal_docs .o_portal_index_card .fs-5,
                    .o_portal_wrap .o_portal_docs .o_portal_index_card .fs-5 {
                        color: #103543;
                        font-weight: 700 !important;
                        font-size: 1.2rem !important;
                    }
                    .o_portal .o_portal_docs .o_portal_index_card .opacity-75,
                    .o_portal_wrap .o_portal_docs .o_portal_index_card .opacity-75 {
                        opacity: 1 !important;
                        color: #5f7280;
                        margin-top: 0.2rem;
                    }
                    .o_portal .o_portal_docs .o_portal_index_card .o_portal_icon,
                    .o_portal_wrap .o_portal_docs .o_portal_index_card .o_portal_icon {
                        display: flex !important;
                        align-items: center;
                        justify-content: center;
                        width: 52px;
                        height: 52px;
                        border-radius: 12px;
                        background: #ebf7f8;
                        flex: 0 0 auto;
                    }
                    .o_portal .o_portal_docs .o_portal_index_card .o_portal_icon img,
                    .o_portal_wrap .o_portal_docs .o_portal_index_card .o_portal_icon img {
                        width: 34px;
                        height: 34px;
                        object-fit: contain;
                    }
                    .o_portal .o_portal_docs .o_portal_index_card .alert-link,
                    .o_portal_wrap .o_portal_docs .o_portal_index_card .alert-link {
                        color: inherit !important;
                    }
