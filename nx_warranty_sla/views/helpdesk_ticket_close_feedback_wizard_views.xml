<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_helpdesk_ticket_close_feedback_wizard_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.close.feedback.wizard.form</field>
        <field name="model">helpdesk.ticket.close.feedback.wizard</field>
        <field name="arch" type="xml">
            <form string="Final Feedback">
                <group>
                    <field name="ticket_id"/>
                    <field name="target_stage_id"/>
                    <field name="final_feedback" placeholder="Write the final feedback that should appear on the portal for this ticket..."/>
                </group>
                <footer>
                    <button name="action_apply" type="object" string="Apply" class="btn btn-primary"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
