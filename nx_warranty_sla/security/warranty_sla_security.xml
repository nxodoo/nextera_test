<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="group_warranty_access" model="res.groups">
            <field name="name">Warranty Access</field>
        </record>
    </data>

    <data noupdate="1">
        <record id="warranty_template_portal_active_rule" model="ir.rule">
            <field name="name">Warranty Template: portal users see active templates only</field>
            <field name="model_id" ref="model_warranty_template"/>
            <field name="domain_force">[('active', '=', True)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>

        <record id="warranty_contract_portal_company_rule" model="ir.rule">
            <field name="name">Warranty Contract: portal users see own company contracts</field>
            <field name="model_id" ref="model_warranty_contract"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.commercial_partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        </record>

        <record id="helpdesk.helpdesk_ticket_user_rule" model="ir.rule">
            <field name="name">Helpdesk Ticket User</field>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('secondary_user_id', '=', user.id)]</field>
        </record>

        <record id="helpdesk_ticket_manager_all_rule" model="ir.rule">
            <field name="name">Helpdesk Ticket: managers see all tickets</field>
            <field name="model_id" ref="helpdesk.model_helpdesk_ticket"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('helpdesk.group_helpdesk_manager'))]"/>
        </record>
    </data>
</odoo>
