<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="website_slides.rule_slide_channel_visibility_public_user" model="ir.rule">
            <field name="domain_force">[
                ('website_published', '=', True),
                ('visibility', '=', 'public'),
                ('nx_allowed_contact_ids', '=', False)
            ]</field>
        </record>

        <record id="website_slides.rule_slide_channel_visibility_signed_in_user" model="ir.rule">
            <field name="domain_force">[
                '&amp;',
                    ('website_published', '=', True),
                    '|',
                        '|',
                            ('is_member_invited', '=', True),
                            ('is_member', '=', True),
                        '|',
                            '&amp;',
                                ('nx_allowed_contact_ids', '=', False),
                                ('visibility', 'in', ('public', 'connected')),
                            ('nx_allowed_contact_ids', '=', user.partner_id.id)
            ]</field>
        </record>

        <record id="website_slides.rule_slide_slide_public_user" model="ir.rule">
            <field name="domain_force">[
                ('channel_id.website_published', '=', True),
                ('website_published', '=', True),
                ('channel_id.visibility', '=', 'public'),
                ('channel_id.nx_allowed_contact_ids', '=', False),
                '|',
                    ('is_category', '=', True),
                    ('is_preview', '=', True)
            ]</field>
        </record>

        <record id="website_slides.rule_slide_slide_signed_in_user" model="ir.rule">
            <field name="domain_force">[
                '&amp;',
                    '|',
                        ('user_id', '=', user.id),
                        '&amp;',
                            ('website_published', '=', True),
                            ('channel_id.website_published', '=', True),
                    '|',
                        '&amp;',
                            '|',
                                '|',
                                    '&amp;',
                                        ('channel_id.nx_allowed_contact_ids', '=', False),
                                        ('channel_id.visibility', 'in', ('public', 'connected')),
                                    ('channel_id.nx_allowed_contact_ids', '=', user.partner_id.id),
                                ('channel_id.is_member_invited', '=', True),
                            '|',
                                ('is_category', '=', True),
                                ('is_preview', '=', True),
                        ('channel_id.is_member', '=', True)
            ]</field>
        </record>
    </data>
</odoo>
