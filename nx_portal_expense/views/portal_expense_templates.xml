<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_expense_form" name="Portal Expense Form">
        <t t-call="portal.portal_layout">
            <t t-set="title">New Expense</t>

            <div class="container mt-4">
                <h3>New Expense</h3>

                <form action="/my/expenses/create" method="post" class="mt-3">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <!-- Description -->
                    <div class="mb-3">
                        <label>Description</label>
                        <input type="text" name="description" class="form-control"
                               placeholder="e.g. Lunch with Customer" required="1"/>
                    </div>

                    <!-- Category + Date -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label>Category</label>
                            <select name="product_id" class="form-select" required="1">
                                <t t-foreach="categories" t-as="cat">
                                    <option t-att-value="cat.id">
                                        <t t-esc="cat.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label>Expense Date</label>
                            <input type="date" name="date" class="form-control"
                                   t-att-value="today" required="1"/>
                        </div>
                    </div>

                    <!-- Total + Currency -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label>Total</label>
                            <input type="number" step="0.01" name="amount"
                                   class="form-control" required="1"/>
                        </div>

                        <div class="col-md-6">
                            <label>Currency</label>
                            <select name="currency_id" class="form-select">
                                <t t-foreach="currencies" t-as="cur">
                                    <option t-att-value="cur.id">
                                        <t t-esc="cur.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                    </div>

                    <!-- Taxes + Account -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label>Included Taxes</label>
                            <select name="tax_ids" id="tax_ids"
                                    class="form-control"
                                    multiple="multiple">
                                <t t-foreach="taxes" t-as="tax">
                                    <option t-att-value="tax.id">
                                        <t t-esc="tax.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label>Account</label>
                            <select name="account_id" class="form-select">
                                <t t-foreach="accounts" t-as="acc">
                                    <option t-att-value="acc.id">
                                        <t t-esc="acc.code"/>
                                        -
                                        <t t-esc="acc.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                    </div>

                    <!-- Paid By + Vendor -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label>Paid By</label>
                            <select name="payment_mode" id="payment_mode"
                                    class="form-select">
                                <option value="own_account">Employee (to reimburse)</option>
                                <option value="company_account">Company</option>
                            </select>
                        </div>

                        <div class="col-md-6" id="vendor_field" style="display:none;">
                            <label>Vendor</label>
                            <select name="vendor_id" class="form-select">
                                <t t-foreach="vendors" t-as="v">
                                    <option t-att-value="v.id">
                                        <t t-esc="v.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        Submit Expense
                    </button>
                </form>
            </div>

            <!-- CSS -->
            <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet"/>

            <style>
                .select2-container--default .select2-selection--multiple {
                border: 1px solid #ced4da;
                border-radius: 0.375rem;
                min-height: 38px;
                padding: 2px 8px;
                }

                .select2-container--default .select2-selection--multiple .select2-selection__choice {
                background-color: #6c757d;
                border: none;
                color: white;
                padding: 4px 10px;
                border-radius: 4px;
                margin: 2px;
                }

                .select2-container--default .select2-selection--multiple .select2-selection__choice__remove {
                color: white;
                margin-right: 5px;
                }

                .select2-container--default .select2-selection--multiple .select2-selection__choice__remove:hover {
                color: #ff6b6b;
                }

                .select2-container {
                width: 100% !important;
                }
            </style>

            <!-- JS -->
            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

            <script>
                $(document).ready(function() {
                $('#tax_ids').select2({
                placeholder: "Select Taxes",
                allowClear: true,
                width: '100%'
                });

                const paymentMode = document.getElementById('payment_mode');
                const vendorField = document.getElementById('vendor_field');

                paymentMode.addEventListener('change', function () {
                vendorField.style.display =
                this.value === 'company_account' ? 'block' : 'none';
                });
                });
            </script>

        </t>
    </template>

    <template id="portal_expense_edit_form" name="Portal Expense Edit Form">
        <t t-call="portal.portal_layout">
            <t t-set="title">Edit Expense</t>

            <div class="container mt-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3>Edit Expense</h3>
                    <a href="/my/expenses" class="btn btn-secondary">
                        Back to List
                    </a>
                </div>

                <t t-if="expense.state != 'draft'">
                    <div class="alert alert-warning">
                        You can only edit expenses in draft state.
                    </div>
                </t>

                <form t-if="expense.state == 'draft'"
                      t-att-action="'/my/expenses/update/%s' % expense.id"
                      method="post"
                      class="mt-3">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                    <!-- Description -->
                    <div class="mb-3">
                        <label>Description</label>
                        <input type="text" name="description" class="form-control"
                               t-att-value="expense.name"
                               placeholder="e.g. Lunch with Customer" required="1"/>
                    </div>

                    <!-- Category + Date -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label>Category</label>
                            <select name="product_id" class="form-select" required="1">
                                <t t-foreach="categories" t-as="cat">
                                    <option t-att-value="cat.id"
                                            t-att-selected="'selected' if cat.id == expense.product_id.id else None">
                                        <t t-esc="cat.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label>Expense Date</label>
                            <input type="date" name="date" class="form-control"
                                   t-att-value="expense.date" required="1"/>
                        </div>
                    </div>

                    <!-- Total + Currency -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label>Total</label>
                            <input type="number" step="0.01" name="amount"
                                   t-att-value="expense.total_amount"
                                   class="form-control" required="1"/>
                        </div>

                        <div class="col-md-6">
                            <label>Currency</label>
                            <select name="currency_id" class="form-select">
                                <t t-foreach="currencies" t-as="cur">
                                    <option t-att-value="cur.id"
                                            t-att-selected="'selected' if cur.id == expense.currency_id.id else None">
                                        <t t-esc="cur.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                    </div>

                    <!-- Taxes + Account -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label>Included Taxes</label>
                            <select name="tax_ids" id="tax_ids"
                                    class="form-control"
                                    multiple="multiple">
                                <t t-foreach="taxes" t-as="tax">
                                    <option t-att-value="tax.id"
                                            t-att-selected="'selected' if tax.id in expense.tax_ids.ids else None">
                                        <t t-esc="tax.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label>Account</label>
                            <select name="account_id" class="form-select">
                                <t t-foreach="accounts" t-as="acc">
                                    <option t-att-value="acc.id"
                                            t-att-selected="'selected' if acc.id == expense.account_id.id else None">
                                        <t t-esc="acc.code"/>
                                        -
                                        <t t-esc="acc.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                    </div>

                    <!-- Paid By + Vendor -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label>Paid By</label>
                            <select name="payment_mode" id="payment_mode" class="form-select">
                                <option value="own_account"
                                        t-att-selected="'selected' if expense.payment_mode == 'own_account' else None">
                                    Employee (to reimburse)
                                </option>
                                <option value="company_account"
                                        t-att-selected="'selected' if expense.payment_mode == 'company_account' else None">
                                    Company
                                </option>
                            </select>
                        </div>

                        <div class="col-md-6" id="vendor_field"
                             t-att-style="'display: block;' if expense.payment_mode == 'company_account' else 'display: none;'">
                            <label>Vendor</label>
                            <select name="vendor_id" class="form-select">
                                <option value="">-- Select Vendor --</option>
                                <t t-foreach="vendors" t-as="v">
                                    <option t-att-value="v.id"
                                            t-att-selected="'selected' if expense.vendor_id and v.id == expense.vendor_id.id else None">
                                        <t t-esc="v.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            Update Expense
                        </button>
                        <a href="/my/expenses" class="btn btn-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>

            <!-- CSS -->
            <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet"/>

            <style>
                .select2-container--default .select2-selection--multiple {
                border: 1px solid #ced4da;
                border-radius: 0.375rem;
                min-height: 38px;
                padding: 2px 8px;
                }

                .select2-container--default .select2-selection--multiple .select2-selection__choice {
                background-color: #6c757d;
                border: none;
                color: white;
                padding: 4px 10px;
                border-radius: 4px;
                margin: 2px;
                }

                .select2-container--default .select2-selection--multiple .select2-selection__choice__remove {
                color: white;
                margin-right: 5px;
                }

                .select2-container--default .select2-selection--multiple .select2-selection__choice__remove:hover {
                color: #ff6b6b;
                }

                .select2-container {
                width: 100% !important;
                }
            </style>

            <!-- JS -->
            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

            <script>
                $(document).ready(function() {
                $('#tax_ids').select2({
                placeholder: "Select Taxes",
                allowClear: true,
                width: '100%'
                });

                const paymentMode = document.getElementById('payment_mode');
                const vendorField = document.getElementById('vendor_field');

                paymentMode.addEventListener('change', function () {
                vendorField.style.display =
                this.value === 'company_account' ? 'block' : 'none';
                });
                });
            </script>
        </t>
    </template>

    <template id="portal_expense_view" name="Portal Expense View">
        <t t-call="portal.portal_layout">
            <t t-set="title">View Expense</t>
            <!-- Status Badge -->
            <div class="mb-3">
                <label>Status</label>
                <div>
                    <span t-att-class="'badge fs-6 ' + ('bg-secondary' if expense.state == 'draft' else 'bg-info' if expense.state == 'reported' else 'bg-success' if expense.state == 'approved' else 'bg-warning' if expense.state == 'done' else 'bg-danger')">
                        <t t-esc="expense.state.upper()"/>
                    </span>
                </div>
            </div>

            <div class="container mt-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3>View Expense</h3>
                    <a href="/my/expenses" class="btn btn-secondary">
                        Back to List
                    </a>
                </div>

                <!-- Alert if not draft -->
                <div class="alert alert-info">
                    <i class="fa fa-info-circle"></i>
                    This expense is in
                    <strong>
                        <t t-esc="expense.state.upper()"/>
                    </strong>
                    state and cannot be edited.
                </div>

                <!-- Form (Disabled) -->
                <form class="mt-3">
                    <!-- Description -->
                    <div class="mb-3">
                        <label>Description</label>
                        <input type="text" name="description" class="form-control"
                               t-att-value="expense.name"
                               disabled="disabled"/>
                    </div>

                    <!-- Category + Date -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label>Category</label>
                            <select name="product_id" class="form-select" disabled="disabled">
                                <option selected="selected">
                                    <t t-esc="expense.product_id.name"/>
                                </option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label>Expense Date</label>
                            <input type="date" name="date" class="form-control"
                                   t-att-value="expense.date" disabled="disabled"/>
                        </div>
                    </div>

                    <!-- Total + Currency -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label>Total</label>
                            <input type="number" step="0.01" name="amount"
                                   t-att-value="expense.total_amount"
                                   class="form-control" disabled="disabled"/>
                        </div>

                        <div class="col-md-6">
                            <label>Currency</label>
                            <select name="currency_id" class="form-select" disabled="disabled">
                                <option selected="selected">
                                    <t t-esc="expense.currency_id.name"/>
                                </option>
                            </select>
                        </div>
                    </div>

                    <!-- Taxes + Account -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label>Included Taxes</label>
                            <div class="form-control" style="min-height: 38px; background-color: #e9ecef;">
                                <t t-if="expense.tax_ids">
                                    <t t-foreach="expense.tax_ids" t-as="tax">
                                        <span class="badge bg-secondary me-1">
                                            <t t-esc="tax.name"/>
                                        </span>
                                    </t>
                                </t>
                                <t t-else="">
                                    <span class="text-muted">No taxes</span>
                                </t>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label>Account</label>
                            <select name="account_id" class="form-select" disabled="disabled">
                                <option selected="selected" t-if="expense.account_id">
                                    <t t-esc="expense.account_id.code"/>
                                    -
                                    <t t-esc="expense.account_id.name"/>
                                </option>
                            </select>
                        </div>
                    </div>

                    <!-- Paid By + Vendor -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label>Paid By</label>
                            <select name="payment_mode" class="form-select" disabled="disabled">
                                <option selected="selected">
                                    <t t-if="expense.payment_mode == 'own_account'">
                                        Employee (to reimburse)
                                    </t>
                                    <t t-else="">
                                        Company
                                    </t>
                                </option>
                            </select>
                        </div>

                        <div class="col-md-6" t-if="expense.vendor_id">
                            <label>Vendor</label>
                            <select name="vendor_id" class="form-select" disabled="disabled">
                                <option selected="selected">
                                    <t t-esc="expense.vendor_id.name"/>
                                </option>
                            </select>
                        </div>
                    </div>

                </form>

                <!-- Additional Info Card -->
                <div class="card mt-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Additional Information</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6" t-if="expense.employee_id">
                                <strong>Employee:</strong>
                                <p>
                                    <t t-esc="expense.employee_id.name"/>
                                </p>
                            </div>
                            <div class="col-md-6" t-if="expense.create_date">
                                <strong>Created:</strong>
                                <p>
                                    <t t-esc="expense.create_date"/>
                                </p>
                            </div>
                        </div>
                        <div class="row" t-if="expense.write_date">
                            <div class="col-md-6">
                                <strong>Last Updated:</strong>
                                <p>
                                    <t t-esc="expense.write_date"/>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <style>
                /* Style for disabled fields */
                .form-control:disabled,
                .form-select:disabled {
                background-color: #e9ecef;
                opacity: 1;
                cursor: not-allowed;
                }
            </style>
        </t>
    </template>
</odoo>