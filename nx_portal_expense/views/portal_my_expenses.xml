<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_my_expenses" name="My Expenses">
        <t t-call="portal.portal_layout">
            <t t-set="title">My Expenses</t>

            <div class="container mt-4">
                <!-- Header + Button -->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3>My Expenses</h3>
                    <a href="/my/expenses/new" class="btn btn-primary">
                        New Expense
                    </a>
                </div>

                <!-- Expenses Table -->
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Description</th>
                            <th>Paid By</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="expenses" t-as="exp">
                            <tr>
                                <td>
                                    <t t-esc="exp.date"/>
                                </td>
                                <td>
                                    <t t-esc="exp.name"/>
                                </td>
                                <td>
                                    <t t-esc="dict(exp._fields['payment_mode'].selection).get(exp.payment_mode)"/>
                                </td>
                                <td>
                                    <t t-esc="'%.2f' % exp.total_amount"/>
                                    <t t-esc="exp.currency_id.symbol"/>
                                </td>
                                <td>
                                    <span t-att-class="'badge ' + ('bg-secondary' if exp.state == 'draft' else 'bg-info' if exp.state == 'reported' else 'bg-success' if exp.state == 'approved' else 'bg-danger')">
                                        <t t-esc="exp.state.upper()"/>
                                    </span>
                                </td>
                                <td>
                                    <a t-att-href="'/my/expenses/edit/%s' % exp.id"
                                       class="btn btn-sm btn-outline-primary"
                                       t-if="exp.state == 'draft'">
                                        Edit
                                    </a>
                                    <a t-att-href="'/my/expenses/view/%s' % exp.id"
                                       class="btn btn-sm btn-outline-secondary"
                                       t-else="">
                                        View
                                    </a>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>

                <t t-if="not expenses">
                    <div class="alert alert-info">
                        No expenses found.
                    </div>
                </t>
            </div>
        </t>
    </template>
</odoo>