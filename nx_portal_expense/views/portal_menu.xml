<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========================= -->
    <!-- Portal Menu -->
    <!-- ========================= -->

    <template id="portal_task_card" inherit_id="portal.portal_my_home" name="Portal: Task Requests Card">
        <xpath expr="//div[contains(@class,'o_portal_docs')]" position="inside">
            <div class="o_portal_category row g-2 mt-3" id="portal_task_category">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="url" t-value="'/my/expenses'"/>
                    <t t-set="title">My Expense</t>
                    <t t-set="text">View and manage my expense</t>
                    <t t-set="icon" t-value="'/hr_expense/static/img/communication.svg'"/>
                    <t t-set="bg_color" t-value="'bg-light'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
            </div>
        </xpath>
    </template>
</odoo>
