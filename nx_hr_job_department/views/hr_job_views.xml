<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_job_form_department" model="ir.ui.view">
        <field name="name">hr.job.form.department</field>
        <field name="model">hr.job</field>
        <field name="inherit_id" ref="hr.view_hr_job_form"/>
        <field name="arch" type="xml">

            <!-- Surface the Department field on the main form -->
            <xpath expr="//div[@class='oe_title']" position="after">
                <group>
                    <field name="department_id"/>
                </group>
            </xpath>

            <!-- Remove the original (hidden) department field to avoid duplicates -->
            <xpath expr="//page[@name='recruitment_page']//field[@name='department_id']"
                   position="replace"/>

        </field>
    </record>
</odoo>
