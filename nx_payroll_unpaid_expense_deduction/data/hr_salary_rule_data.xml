<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="salary_rule_unpaid_approved_expenses_template" model="hr.salary.rule">
            <field name="name">Deduction - Unpaid Approved Expenses</field>
            <field name="code">UNPAID_EXP</field>
            <field name="struct_id" ref="hr_payroll.default_structure"/>
            <field name="sequence">175</field>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="appears_on_payslip">True</field>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
payload = payslip._get_unpaid_expense_salary_rule_result(categories)
result = payload['amount']
result_name = payload['name']
            </field>
            <field name="note" type="html">
                <p>Automatically deduct approved unpaid expenses that fall inside the payslip period and were not already linked to another payslip.</p>
            </field>
        </record>
    </data>
</odoo>
