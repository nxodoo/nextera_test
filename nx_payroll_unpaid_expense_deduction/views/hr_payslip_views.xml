<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_payslip_form_inherit_expense_deduction" model="ir.ui.view">
        <field name="name">hr.payslip.form.inherit.expense.deduction</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button type="object"
                        class="oe_stat_button"
                        name="action_open_deducted_expenses"
                        icon="fa-credit-card"
                        invisible="deducted_expense_count == 0">
                    <field name="deducted_expense_count" widget="statinfo" string="Deducted Expenses"/>
                </button>
            </xpath>
            <xpath expr="//div[@class='alert alert-warning' and @name='payslip_alert']" position="after">
                <div class="alert alert-warning" role="alert" invisible="not expense_deduction_warning">
                    <field name="expense_deduction_warning"/>
                </div>
            </xpath>
            <xpath expr="//page[@name='salary_computation']" position="after">
                <page string="Deducted Expenses" name="deducted_expenses">
                    <group col="4">
                        <field name="total_deducted_expenses" readonly="1"/>
                        <field name="deducted_expense_count" readonly="1"/>
                    </group>
                    <field name="deducted_expense_ids" readonly="1" nolabel="1">
                        <list string="Deducted Expenses" create="0" delete="0">
                            <field name="date"/>
                            <field name="name"/>
                            <field name="product_id"/>
                            <field name="total_amount" sum="Total Amount"/>
                            <field name="sheet_id" string="Reference"/>
                            <field name="state"/>
                        </list>
                        <form string="Deducted Expense">
                            <group col="4">
                                <field name="date"/>
                                <field name="name"/>
                                <field name="product_id"/>
                                <field name="total_amount"/>
                                <field name="sheet_id"/>
                                <field name="state"/>
                                <field name="payslip_deduction_id"/>
                            </group>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_hr_payslip_filter_inherit_expense_deduction" model="ir.ui.view">
        <field name="name">hr.payslip.filter.inherit.expense.deduction</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='done']" position="after">
                <filter string="With Expense Deductions"
                        name="with_expense_deductions"
                        domain="[('deducted_expense_ids', '!=', False)]"/>
                <filter string="No Expense Deductions"
                        name="without_expense_deductions"
                        domain="[('deducted_expense_ids', '=', False)]"/>
            </xpath>
        </field>
    </record>
</odoo>
