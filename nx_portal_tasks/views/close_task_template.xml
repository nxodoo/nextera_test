<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ========================= -->
    <!-- Tasks List -->
    <!-- ========================= -->
    <template id="portal_close_tasks_list">
        <t t-call="portal.portal_layout">
            <div class="container mt16 mb16">
                <a class="btn btn-secondary mb8" href="/my/open-tasks">My Open Task</a>
                <t t-if="tasks">
                    <table class="table table-hover o_portal_table">
                        <thead>
                            <tr>
                                <th>Task</th>
                                <th>Project</th>
                                <th>Stage</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="tasks" t-as="task">
                                <tr>
                                    <td>
                                        <a t-att-href="'/my/close-task/%s' % task.id">
                                            <t t-esc="task.name"/>
                                        </a>
                                    </td>
                                    <td>
                                        <t t-esc="task.project_id.name"/>
                                    </td>
                                    <td>
                                        <t t-esc="task.stage_id.name"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
                <t t-else="">
                    <div class="alert alert-info mt-3">
                        No close tasks found.
                    </div>
                </t>
            </div>
        </t>
    </template>


    <!-- ========================= -->
    <!-- Task Form -->
    <!-- ========================= -->
    <template id="portal_close_task_form">
        <t t-call="portal.portal_layout">

            <!-- ================= HEADER INFO ================= -->
            <div class="row mb-3">
                <div class="col-md-6">
                    <p>
                        <strong>Project:</strong>
                        <t t-esc="task.project_id.name"/>
                    </p>
                    <p>
                        <strong>Milestone:</strong>
                        <t t-if="task.milestone_id">
                            <t t-esc="task.milestone_id.name"/>
                        </t>
                        <t t-else="">-</t>
                    </p>
                    <p>
                        <strong>Assignees:</strong>
                        <t t-if="task.user_ids">
                            <t t-foreach="task.user_ids" t-as="user">
                                <span class="badge bg-secondary me-1">
                                    <t t-esc="user.name"/>
                                </span>
                            </t>
                        </t>
                        <t t-else="">-</t>
                    </p>
                </div>
                <div class="col-md-6">
                    <!--                <p><strong>Customer:</strong> <t t-if="task.partner_id"> <t t-esc="task.partner_id.name"/> </t> <t t-else="">-</t></p>-->
                    <!--                <p><strong>Sales Order Item:</strong> <t t-if="task.sale_order_line_id"> <t t-esc="task.sale_order_line_id.display_name"/> </t> <t t-else="">-</t></p>-->
                    <p>
                        <strong>Deadline:</strong>
                        <t t-if="task.date_deadline">
                            <t t-esc="task.date_deadline"/>
                        </t>
                        <t t-else="">-</t>
                    </p>
                    <p>
                        <strong>Allocated Time:</strong>
                        <t t-esc="task.planned_hours or 0"/>
                        (0%)
                    </p>
                </div>
            </div>

            <!-- ================= TABS ================= -->
            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <a class="nav-link active" id="description-tab" data-bs-toggle="tab" href="#description" role="tab">
                        Description
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" id="timesheets-tab" data-bs-toggle="tab" href="#timesheets" role="tab">
                        Timesheets
                    </a>
                </li>
                <!-- <li class="nav-item">
                     <a class="nav-link" id="subtasks-tab" data-bs-toggle="tab" href="#subtasks" role="tab">Sub-tasks</a>
                 </li>
                 <li class="nav-item">
                     <a class="nav-link" id="extra-tab" data-bs-toggle="tab" href="#extra" role="tab">Extra Info</a>
                 </li>-->
            </ul>

            <div class="tab-content mt-3">
                <!-- ========== Description Tab ========== -->
                <div class="tab-pane fade show active" id="description" role="tabpanel">
                    <p t-if="task.description" t-raw="task.description"/>
                    <p t-else="">No description available.</p>
                </div>

                <!-- ========== Timesheets Tab ========== -->
                <div class="tab-pane fade" id="timesheets" role="tabpanel">
                    <table class="table table-sm table-hover">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Employee</th>
                                <th>Description</th>
                                <th>Time Spent</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="timesheets">
                                <t t-foreach="timesheets" t-as="ts">
                                    <tr>
                                        <td>
                                            <t t-esc="ts.date"/>
                                        </td>
                                        <td>
                                            <t t-esc="ts.employee_id.name"/>
                                        </td>
                                        <td>
                                            <t t-esc="ts.name"/>
                                        </td>
                                        <td>
                                            <t t-esc="ts.unit_amount"/>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                            <t t-else="">
                                <tr>
                                    <td colspan="4" class="text-center text-muted">No timesheets found.</td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <!-- Times Summary -->
                    <div class="mt-3 text-end">
                        <p>
                            <strong>Time Spent:</strong>
                            <t t-esc="sum([ts.unit_amount for ts in timesheets]) if timesheets else 0"/>
                        </p>
                        <p>
                            <strong>Time Remaining:</strong>
                            <t t-esc="(task.planned_hours or 0) - (sum([ts.unit_amount for ts in timesheets]) if timesheets else 0)"/>
                        </p>
                    </div>
                </div>

                <!-- ========== Sub-tasks Tab ========== -->
                <!--<div class="tab-pane fade" id="subtasks" role="tabpanel">
                    <p>Sub-tasks list will appear here...</p>
                </div>-->

                <!-- ========== Extra Info Tab ========== -->
                <!--<div class="tab-pane fade" id="extra" role="tabpanel">
                    <p>Extra information about the task will appear here...</p>
                </div>-->
            </div>
        </t>
    </template>


</odoo>
