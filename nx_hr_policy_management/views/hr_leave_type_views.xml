<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_leave_type_form_inherit_policy_management" model="ir.ui.view">
        <field name="name">hr.leave.type.form.inherit.policy.management</field>
        <field name="model">hr.leave.type</field>
        <field name="inherit_id" ref="hr_holidays.edit_holiday_status_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='configuration']/field[@name='show_on_dashboard']" position="after">
                <field name="hide_from_employee" groups="hr_holidays.group_hr_holidays_manager"/>
            </xpath>
        </field>
    </record>

    <record id="view_hr_leave_type_tree_inherit_policy_management" model="ir.ui.view">
        <field name="name">hr.leave.type.list.inherit.policy.management</field>
        <field name="model">hr.leave.type</field>
        <field name="inherit_id" ref="hr_holidays.view_holiday_status_normal_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='employee_requests']" position="after">
                <field name="hide_from_employee" optional="hide" groups="hr_holidays.group_hr_holidays_manager"/>
            </xpath>
        </field>
    </record>
</odoo>
