<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_resource_calendar_leave_form_holiday_greeting" model="ir.ui.view">
        <field name="name">resource.calendar.leaves.form.holiday.greeting</field>
        <field name="model">resource.calendar.leaves</field>
        <field name="inherit_id" ref="hr_holidays.resource_calendar_leave_form_inherit"/>
        <field name="arch" type="xml">
            <field name="holiday_id" position="after">
                <field
                    name="holiday_greeting_template_id"
                    options="{'no_create_edit': False}"
                    invisible="resource_id"
                />
            </field>
        </field>
    </record>

    <record id="view_resource_calendar_leave_tree_holiday_greeting" model="ir.ui.view">
        <field name="name">resource.calendar.leaves.tree.holiday.greeting</field>
        <field name="model">resource.calendar.leaves</field>
        <field name="inherit_id" ref="hr_holidays.resource_calendar_leaves_tree_inherit"/>
        <field name="arch" type="xml">
            <field name="company_id" position="after">
                <field name="holiday_greeting_template_id" optional="hide"/>
            </field>
        </field>
    </record>
</odoo>
