<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_form_inherit_leave_allowance" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.leave.allowance</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='public']//field[@name='tz']/ancestor::group[1]" position="after">
                <group string="Leave Allowance">
                    <field name="years_of_service" readonly="1"/>
                    <field name="next_allowance_date" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
