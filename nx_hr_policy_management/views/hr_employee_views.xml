<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_form_inherit_leave_allowance" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.leave.allowance</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority">8</field>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='public']//field[@name='resource_calendar_id']/ancestor::group[1]" position="replace"/>
            <xpath expr="//page[@name='public']//field[@name='address_id']/ancestor::group[1]" position="replace">
                <group name="nx_location_schedule_row">
                    <group name="nx_location" string="Location">
                        <field name="address_id"
                               context="{'show_address': 1}"
                               options='{"highlight_first_line": True}'/>
                        <field name="work_location_id"
                               context="{'default_address_id': address_id}"
                               placeholder="e.g. Building 2, Remote, etc."/>
                    </group>
                    <group name="nx_schedule" string="Schedule">
                        <field name="resource_calendar_id" help="The default working hours are set in configuration."/>
                        <field name="id" invisible="1"/>
                        <field name="tz" required="id"/>
                    </group>
                </group>
            </xpath>
            <xpath expr="//page[@name='public']//group[@name='managers']" position="replace">
                <group name="nx_approvers_allowance_row">
                    <group name="managers" string="Approvers" class="hide-group-if-empty" invisible="1">
                        <!-- is overridden in other hr related modules -->
                    </group>
                    <group name="nx_leave_allowance" string="Leave Allowance">
                        <field name="years_of_service" readonly="1"/>
                        <field name="next_allowance_date" readonly="1"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
