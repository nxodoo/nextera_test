<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="seq_hr_letter_request" model="ir.sequence">
        <field name="name">HR Letter Request</field>
        <field name="code">hr.letter.request</field>
        <field name="prefix">LTR-%(year)s-</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_hr_business_trip" model="ir.sequence">
        <field name="name">Business Trip Request</field>
        <field name="code">hr.business.trip</field>
        <field name="prefix">TRP-%(year)s-</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
