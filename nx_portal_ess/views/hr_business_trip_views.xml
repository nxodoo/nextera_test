<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_business_trip_list" model="ir.ui.view">
        <field name="name">hr.business.trip.list</field>
        <field name="model">hr.business.trip</field>
        <field name="arch" type="xml">
            <list string="Business Trips">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="destination"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="duration"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('approved','done')"
                       decoration-danger="state == 'refused'"
                       decoration-info="state == 'submitted'"/>
            </list>
        </field>
    </record>

    <record id="view_hr_business_trip_form" model="ir.ui.view">
        <field name="name">hr.business.trip.form</field>
        <field name="model">hr.business.trip</field>
        <field name="arch" type="xml">
            <form string="Business Trip">
                <header>
                    <button name="action_submit" type="object" string="Submit"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve"
                            class="btn-primary" invisible="state != 'submitted'"/>
                    <button name="action_done" type="object" string="Complete"
                            invisible="state != 'approved'"/>
                    <button name="action_refuse" type="object" string="Refuse"
                            invisible="state in ('refused','done')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="destination"/>
                            <field name="estimated_cost"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="duration"/>
                        </group>
                    </group>
                    <group string="Purpose">
                        <field name="purpose" nolabel="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_hr_business_trip" model="ir.actions.act_window">
        <field name="name">Business Trips</field>
        <field name="res_model">hr.business.trip</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No business trips yet</p>
            <p>Trip requests submitted by employees from the ESS portal appear here.</p>
        </field>
    </record>

    <menuitem id="menu_hr_business_trip_root"
              name="Business Trips"
              parent="nx_portal_ess.menu_ess_employee_requests"
              action="action_hr_business_trip"
              sequence="20"/>
</odoo>
