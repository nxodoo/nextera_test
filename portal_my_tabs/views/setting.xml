<odoo>
    <record id="view_website_config_portal_mode" model="ir.ui.view">
        <field name="name">website.config.portal.mode</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="website.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//app[@name='website']" position="inside">

                <block title="NX Portal Settings" name="nx_portal_settings">

                    <setting string="Portal Mode">
                        <field name="portal_mode"/>
                    </setting>

                </block>

            </xpath>
        </field>
    </record>




</odoo>