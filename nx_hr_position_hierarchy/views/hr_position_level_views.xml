<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_position_level_list" model="ir.ui.view">
        <field name="name">hr.position.level.list</field>
        <field name="model">hr.position.level</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="is_assistant"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_hr_position_level_form" model="ir.ui.view">
        <field name="name">hr.position.level.form</field>
        <field name="model">hr.position.level</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="is_assistant"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hr_position_level_search" model="ir.ui.view">
        <field name="name">hr.position.level.search</field>
        <field name="model">hr.position.level</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <filter string="Assistant" name="assistant" domain="[('is_assistant', '=', True)]"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_hr_position_level" model="ir.actions.act_window">
        <field name="name">Position Levels</field>
        <field name="res_model">hr.position.level</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hr_position_level_search"/>
    </record>

    <menuitem id="menu_hr_position_level"
              name="Position Levels"
              parent="hr.menu_human_resources_configuration"
              action="action_hr_position_level"
              groups="hr.group_hr_user"
              sequence="6"/>
</odoo>
