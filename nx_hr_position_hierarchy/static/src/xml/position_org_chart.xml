<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="nx_hr_position_hierarchy.PositionOrgChart">
        <div class="o_nx_position_org_chart h-100 d-flex flex-column">
            <div class="o_nx_position_header border-bottom bg-white">
                <div class="d-flex align-items-center justify-content-between px-4 py-3">
                    <h2 class="m-0 fs-4" t-esc="pageTitle"/>
                    <div class="btn-group" role="group" aria-label="Org chart view mode">
                        <button class="btn btn-light active" type="button">Position View</button>
                    </div>
                </div>
                <div class="d-flex flex-wrap align-items-center gap-3 px-4 pb-3">
                    <label class="d-flex align-items-center gap-2 m-0">
                        <span>Department</span>
                        <select class="form-select form-select-sm" t-att-value="state.departmentId" t-on-change="onDepartmentChange">
                            <option value="">All departments</option>
                            <t t-foreach="state.departments" t-as="department" t-key="department.id">
                                <option t-att-value="department.id">
                                    <t t-esc="department.name"/>
                                </option>
                            </t>
                        </select>
                    </label>
                    <label class="d-flex align-items-center gap-2 m-0">
                        <span>Level</span>
                        <select class="form-select form-select-sm" t-att-value="state.level" t-on-change="onLevelChange">
                            <option value="">All levels</option>
                            <t t-foreach="state.levels" t-as="level" t-key="level.id">
                                <option t-att-value="level.id">
                                    <t t-esc="level.name"/>
                                </option>
                            </t>
                        </select>
                    </label>
                    <label class="form-check d-flex align-items-center gap-2 m-0">
                        <input class="form-check-input m-0" type="checkbox" t-att-checked="state.showVacant" t-on-change="onShowVacantChange"/>
                        <span>Show vacant</span>
                    </label>
                    <div class="ms-auto d-flex gap-3 text-muted">
                        <span><b t-esc="state.summary.positions || 0"/> Positions</span>
                        <span><b t-esc="state.summary.filled || 0"/> Filled</span>
                        <span><b t-esc="state.summary.vacant || 0"/> Vacant</span>
                    </div>
                </div>
            </div>
            <div class="o_nx_position_canvas flex-grow-1 overflow-auto">
                <div t-if="state.loading" class="o_nx_position_empty">Loading...</div>
                <div t-elif="!state.nodes.length" class="o_nx_position_empty">No positions match the selected filters.</div>
                <div t-else="" class="o_nx_position_tree_roots">
                    <t t-foreach="state.nodes" t-as="node" t-key="node.id">
                        <PositionOrgChartNode node="node"
                                              collapsedNodes="state.collapsedNodes"
                                              isCollapsed.bind="isCollapsed"
                                              toggleNode.bind="toggleNode"
                                              openJob.bind="openJob"
                                              openEmployee.bind="openEmployee"/>
                    </t>
                </div>
            </div>
        </div>
    </t>

    <t t-name="nx_hr_position_hierarchy.PositionOrgChartNode">
        <div class="o_nx_position_node_wrap">
            <div t-attf-class="o_nx_position_node_body #{props.node.children.length ? 'o_nx_has_children' : ''} #{props.node.assistant_children.length ? 'o_nx_has_assistant' : ''} #{props.isCollapsed(props.node.id) ? 'o_nx_children_collapsed' : ''}">
                <div class="o_nx_position_parent_slot">
                    <div role="button"
                         tabindex="0"
                         t-attf-class="o_nx_position_card o_nx_position_{{props.node.status}} #{props.node.is_assistant ? 'o_nx_position_assistant_card' : ''}"
                         t-on-click="() => props.openJob(props.node.id)">
                        <div class="d-flex align-items-start justify-content-between gap-2">
                            <span class="o_nx_position_dept" t-esc="props.node.department_name || 'No department'"/>
                            <span t-attf-class="o_nx_position_status o_nx_position_status_{{props.node.status}}">
                                <t t-if="props.node.status === 'filled'">Filled</t>
                                <t t-else="">Vacant</t>
                            </span>
                        </div>
                        <strong class="o_nx_position_name" t-esc="props.node.name"/>
                        <span class="o_nx_position_level" t-esc="props.node.level_name"/>
                        <div class="o_nx_position_people">
                            <t t-if="props.node.employees.length">
                                <t t-foreach="props.node.employees" t-as="employee" t-key="employee.id">
                                    <button type="button" class="o_nx_position_employee o_nx_position_employee_button" t-on-click.stop="() => props.openEmployee(employee.id)">
                                        <span class="o_nx_position_avatar" t-att-style="'background-image: url(' + employee.avatar_url + ')'"/>
                                        <span t-esc="employee.name"/>
                                    </button>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="o_nx_position_employee text-muted">
                                    <span class="o_nx_position_avatar o_nx_position_avatar_empty"/>
                                    <span>No assignee</span>
                                </div>
                            </t>
                        </div>
                        <div class="o_nx_position_headcount">
                            <span>Headcount <t t-esc="props.node.assigned_count"/>/<t t-esc="props.node.headcount"/></span>
                            <span t-if="props.node.status === 'vacant' &amp;&amp; props.node.target_count">Target <t t-esc="props.node.target_count"/></span>
                        </div>
                        <button t-if="props.node.children.length"
                                type="button"
                                t-attf-class="o_nx_position_toggle #{props.isCollapsed(props.node.id) ? 'o_nx_position_toggle_collapsed' : ''}"
                                t-on-click.stop="() => props.toggleNode(props.node.id)"
                                t-att-aria-expanded="!props.isCollapsed(props.node.id)">
                            <i t-attf-class="fa #{props.isCollapsed(props.node.id) ? 'fa-caret-right' : 'fa-caret-down'}"/>
                            <span><t t-esc="props.node.children.length"/> Positions</span>
                        </button>
                    </div>
                    <div t-if="props.node.assistant_children.length" class="o_nx_position_assistants">
                        <t t-foreach="props.node.assistant_children" t-as="assistant" t-key="assistant.id">
                            <div class="o_nx_position_assistant_branch">
                                <div role="button"
                                     tabindex="0"
                                     t-attf-class="o_nx_position_card o_nx_position_{{assistant.status}} o_nx_position_assistant_card"
                                     t-on-click="() => props.openJob(assistant.id)">
                                    <div class="d-flex align-items-start justify-content-between gap-2">
                                        <span class="o_nx_position_dept" t-esc="assistant.department_name || 'No department'"/>
                                        <span t-attf-class="o_nx_position_status o_nx_position_status_{{assistant.status}}">
                                            <t t-if="assistant.status === 'filled'">Filled</t>
                                            <t t-else="">Vacant</t>
                                        </span>
                                    </div>
                                    <strong class="o_nx_position_name" t-esc="assistant.name"/>
                                    <span class="o_nx_position_level" t-esc="assistant.level_name"/>
                                    <div class="o_nx_position_people">
                                        <t t-if="assistant.employees.length">
                                            <t t-foreach="assistant.employees" t-as="employee" t-key="employee.id">
                                                <button type="button" class="o_nx_position_employee o_nx_position_employee_button" t-on-click.stop="() => props.openEmployee(employee.id)">
                                                    <span class="o_nx_position_avatar" t-att-style="'background-image: url(' + employee.avatar_url + ')'"/>
                                                    <span t-esc="employee.name"/>
                                                </button>
                                            </t>
                                        </t>
                                        <t t-else="">
                                            <div class="o_nx_position_employee text-muted">
                                                <span class="o_nx_position_avatar o_nx_position_avatar_empty"/>
                                                <span>No assignee</span>
                                            </div>
                                        </t>
                                    </div>
                                    <div class="o_nx_position_headcount">
                                        <span>Headcount <t t-esc="assistant.assigned_count"/>/<t t-esc="assistant.headcount"/></span>
                                        <span t-if="assistant.status === 'vacant' &amp;&amp; assistant.target_count">Target <t t-esc="assistant.target_count"/></span>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
            <div t-if="props.node.children.length &amp;&amp; !props.isCollapsed(props.node.id)" class="o_nx_position_children">
                <t t-foreach="props.node.children" t-as="child" t-key="child.id">
                    <div class="o_nx_position_child_branch">
                        <PositionOrgChartNode node="child"
                                              collapsedNodes="props.collapsedNodes"
                                              isCollapsed.bind="props.isCollapsed"
                                              toggleNode.bind="props.toggleNode"
                                              openJob.bind="props.openJob"
                                              openEmployee.bind="props.openEmployee"/>
                    </div>
                </t>
            </div>
        </div>
    </t>

</templates>
