<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="nx_payroll_timesheet_work_entry.WebGridButtons"
       t-inherit="web_grid.Buttons"
       t-inherit-mode="extension">
        <xpath expr="//div[@t-if='displayAddALine']" position="after">
            <div class="me-2" t-if="showMassInternalAllocationButton">
                <button class="btn btn-secondary"
                        type="button"
                        t-on-click="() => this.openMassInternalAllocationWizard()">
                    Mass Internal Allocation
                </button>
            </div>
        </xpath>
    </t>

</templates>
