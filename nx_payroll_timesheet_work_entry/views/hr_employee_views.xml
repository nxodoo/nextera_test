<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_employee_form_inherit_timesheet_attendance_flag" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.timesheet.attendance.flag</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='application_group']" position="inside">
                <field name="attendance_based_on_timesheet"/>
            </xpath>
        </field>
    </record>

</odoo>
