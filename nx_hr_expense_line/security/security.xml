<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_hr_expense_line_multi_company_user" model="ir.rule">
        <field name="name">Expense lines multi company user</field>
        <field name="model_id" ref="model_hr_expense_line"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hr_expense.group_hr_expense_user'))]"/>
    </record>

    <record id="rule_hr_expense_line_multi_company_manager" model="ir.rule">
        <field name="name">Expense lines multi company manager</field>
        <field name="model_id" ref="model_hr_expense_line"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hr_expense.group_hr_expense_manager'))]"/>
    </record>

    <record id="rule_hr_expense_line_type_multi_company_manager" model="ir.rule">
        <field name="name">Expense line types multi company manager</field>
        <field name="model_id" ref="model_hr_expense_line_type"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hr_expense.group_hr_expense_manager'))]"/>
    </record>

    <record id="rule_hr_expense_line_type_multi_company_account_manager" model="ir.rule">
        <field name="name">Expense line types multi company account manager</field>
        <field name="model_id" ref="model_hr_expense_line_type"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('account.group_account_manager'))]"/>
    </record>
</odoo>
