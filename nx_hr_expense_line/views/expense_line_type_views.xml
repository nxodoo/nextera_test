<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_expense_line_type_tree" model="ir.ui.view">
        <field name="name">hr.expense.line.type.tree</field>
        <field name="model">hr.expense.line.type</field>
        <field name="arch" type="xml">
            <list string="Expense Line Types">
                <field name="name"/>
                <field name="account_id"/>
                <field name="max_amount"/>
                <field name="active"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_hr_expense_line_type_form" model="ir.ui.view">
        <field name="name">hr.expense.line.type.form</field>
        <field name="model">hr.expense.line.type</field>
        <field name="arch" type="xml">
            <form string="Expense Line Type">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="account_id"/>
                            <field name="max_amount"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="note" placeholder="Internal notes..."/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_hr_expense_line_type_search" model="ir.ui.view">
        <field name="name">hr.expense.line.type.search</field>
        <field name="model">hr.expense.line.type</field>
        <field name="arch" type="xml">
            <search string="Expense Line Types">
                <field name="name"/>
                <field name="account_id"/>
                <field name="company_id"/>
            </search>
        </field>
    </record>

    <record id="action_hr_expense_line_type" model="ir.actions.act_window">
        <field name="name">Expense Line Types</field>
        <field name="res_model">hr.expense.line.type</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_hr_expense_line_type_search"/>
        <field name="domain">[]</field>
    </record>

    <menuitem
        id="menu_hr_expense_line_type"
        name="Expense Line Types"
        parent="hr_expense.menu_hr_expense_configuration"
        action="action_hr_expense_line_type"
        sequence="25"
        groups="hr_expense.group_hr_expense_manager,account.group_account_manager"
    />
</odoo>
