<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_expense_line_tree" model="ir.ui.view">
        <field name="name">hr.expense.line.tree</field>
        <field name="model">hr.expense.line</field>
        <field name="arch" type="xml">
            <list string="Expense Lines">
                <field name="expense_id"/>
                <field name="employee_id"/>
                <field name="expense_line_type_id"/>
                <field name="name"/>
                <field name="date"/>
                <field name="currency_id" optional="show"/>
                <field name="total_amount" widget="monetary" sum="Total"/>
                <field name="state"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_hr_expense_line_pivot" model="ir.ui.view">
        <field name="name">hr.expense.line.pivot</field>
        <field name="model">hr.expense.line</field>
        <field name="arch" type="xml">
            <pivot string="Expense Line Analysis">
                <field name="expense_line_type_id" type="row"/>
                <field name="employee_id" type="row"/>
                <field name="date" interval="month" type="col"/>
                <field name="total_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_hr_expense_line_search" model="ir.ui.view">
        <field name="name">hr.expense.line.search</field>
        <field name="model">hr.expense.line</field>
        <field name="arch" type="xml">
            <search string="Expense Lines">
                <field name="name"/>
                <field name="expense_id"/>
                <field name="expense_line_type_id"/>
                <field name="employee_id"/>
                <field name="company_id"/>
                <filter string="Expense Date" name="date" date="date"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <group expand="0" string="Group By">
                    <filter string="Type" name="group_type" context="{'group_by': 'expense_line_type_id'}"/>
                    <filter string="Expense" name="group_expense" context="{'group_by': 'expense_id'}"/>
                    <filter string="Employee" name="group_employee" context="{'group_by': 'employee_id'}"/>
                    <filter string="State" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Month" name="group_month" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_expense_line_analysis" model="ir.actions.act_window">
        <field name="name">Expense Line Analysis</field>
        <field name="res_model">hr.expense.line</field>
        <field name="view_mode">list,pivot</field>
        <field name="search_view_id" ref="view_hr_expense_line_search"/>
        <field name="domain">[]</field>
    </record>

    <menuitem
        id="menu_hr_expense_line_analysis"
        name="Expense Line Analysis"
        parent="hr_expense.menu_hr_expense_reports"
        action="action_hr_expense_line_analysis"
        sequence="10"
    />
</odoo>
