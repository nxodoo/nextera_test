<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_leave_allocation_form_inherit_alt_dates" model="ir.ui.view">
        <field name="name">hr.leave.allocation.form.inherit.alt.dates</field>
        <field name="model">hr.leave.allocation</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_allocation_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='holiday_status_id']" position="after">
                <field name="alternative_date_from"/>
                <field name="alternative_date_to"/>
            </xpath>
        </field>
    </record>
</odoo>
