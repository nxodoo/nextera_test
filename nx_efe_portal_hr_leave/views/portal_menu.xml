<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="portal_leave_card" inherit_id="portal.portal_my_home" name="Portal: Leave Requests Card">
        <xpath expr="//div[contains(@class,'o_portal_docs')]" position="inside">
            <div class="o_portal_category row g-2 mt-3" id="portal_leave_category">
                <t t-call="portal.portal_docs_entry">
                    <t t-set="url" t-value="'/my/leaves'"/>
                    <t t-set="title">Leave Requests</t>
                    <t t-set="text">View and manage your time off</t>
                    <t t-set="bg_color" t-value="'bg-light'"/>
                    <t t-set="config_card" t-value="True"/>
                </t>
            </div>
        </xpath>
    </template>
</odoo>
