<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_kpi" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.kpi</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr_payroll.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='hr_payroll_settings']" position="inside">
                <setting id="auto_generate_kpi_evaluations_setting"
                         string="Auto Generate KPI Evaluations"
                         company_dependent="1"
                         help="Automatically create draft KPI evaluations for monthly and quarterly payroll periods.">
                    <field name="auto_generate_kpi_evaluations"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
