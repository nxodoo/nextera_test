<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_payslip_kpi_missing_wizard_form" model="ir.ui.view">
        <field name="name">hr.payslip.kpi.missing.wizard.form</field>
        <field name="model">hr.payslip.kpi.missing.wizard</field>
        <field name="arch" type="xml">
            <form string="Missing KPI Evaluations">
                <group>
                    <div class="alert alert-warning" role="alert">
                        <p>The following employees have no KPI defined.</p>
                        <p>You can proceed and calculate KPI as 0, or close this window and complete the evaluation first.</p>
                    </div>
                    <field name="missing_employee_names" nolabel="1" readonly="1"/>
                </group>
                <footer>
                    <button name="action_proceed" type="object" string="Proceed With KPI = 0" class="btn-primary"/>
                    <button name="action_cancel" type="object" string="Go Back" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
