<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="salary_rule_kpi_bonus_template" model="hr.salary.rule">
            <field name="name">KPI Bonus</field>
            <field name="code">KPI</field>
            <field name="struct_id" ref="hr_payroll.default_structure"/>
            <field name="sequence">180</field>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="appears_on_payslip">True</field>
            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
payload = payslip._get_kpi_salary_rule_result(categories)
result = payload['amount']
result_name = payload['name']
            </field>
            <field name="note" type="html">
                <p>Automatically calculates the KPI bonus from the approved KPI evaluation that matches the payslip period.</p>
            </field>
        </record>
    </data>
</odoo>
